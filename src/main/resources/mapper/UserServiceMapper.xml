<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.lz.mapper.UserServiceMapper">

    <!--
        登录查询：
        通过用户名查询用户信息，这里假设表名为 sys_user，
        字段为：id, username, password, real_name, role_id, status, create_time
        如与你实际表结构不同，只需要调整表名和列名即可。
    -->
    <select id="login" parameterType="string" resultType="com.lz.bean.UserBean">
        SELECT
            id,
            username,
            password,
            real_name AS realName,
            role_id AS roleId,
            status,
            create_time AS createTime
        FROM sys_user
        WHERE username = #{username}
          AND status = 1
        LIMIT 1
    </select>

    <!--
        注册用户：
        插入新用户到 sys_user 表
    -->
    <insert id="register" parameterType="com.lz.bean.UserBean" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO sys_user (
            username,
            password,
            real_name,
            role_id,
            status,
            create_time
        ) VALUES (
            #{username},
            #{password},
            #{realName},
            #{roleId},
            #{status},
            NOW()
        )
    </insert>

</mapper>

